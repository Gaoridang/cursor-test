# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# xAI — semantic search (optional until you are ready)
# Add these in Vercel: Project → Settings → Environment Variables
XAI_API_KEY=
XAI_MANAGEMENT_API_KEY=
XAI_COLLECTION_ID=

# Setup checklist:
# 1. Copy this file to .env.local for local development
# 2. Create a Collection at https://console.x.ai
# 3. Add the three XAI_* variables in Vercel (Production + Preview)
# 4. Set NEXT_PUBLIC_SITE_URL to your Vercel URL (e.g. https://your-app.vercel.app)
# 5. Redeploy — build will auto-sync posts to the Collection
