# 사이트
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# xAI — 시맨틱 검색 (준비될 때까지 선택 사항)
# Vercel: Project → Settings → Environment Variables 에 추가
XAI_API_KEY=
XAI_MANAGEMENT_API_KEY=
XAI_COLLECTION_ID=

# 설정 체크리스트:
# 1. 로컬 개발용으로 이 파일을 .env.local 로 복사
# 2. https://console.x.ai 에서 Collection 생성
# 3. Vercel에 XAI_* 변수 3개 추가 (Production + Preview)
# 4. NEXT_PUBLIC_SITE_URL 을 Vercel URL로 설정 (예: https://your-app.vercel.app)
# 5. 재배포 — 빌드 시 글이 Collection에 자동 동기화됨
